@page "/users"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api

<h1 class="text-2xl font-bold tracking-tight text-slate-900 mb-1">Utenti</h1>
<p class="text-sm text-slate-500 mb-6">Staff e clienti del sistema.</p>

<div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200"><h2 class="font-semibold text-slate-900">Elenco (@_items.Count)</h2></div>
        @if (_items.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun utente.</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr><th class="px-5 py-3 font-medium">Email</th><th class="px-5 py-3 font-medium">Nome</th>
                        <th class="px-5 py-3 font-medium">Ruolo</th><th class="px-5 py-3 font-medium">Stato</th></tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var u in _items)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3 font-medium text-slate-900">@u.Email</td>
                            <td class="px-5 py-3 text-slate-600">@(u.FullName ?? "—")</td>
                            <td class="px-5 py-3 text-slate-600">@string.Join(", ", u.Roles)</td>
                            <td class="px-5 py-3">
                                @if (u.IsActive) { <span class="text-xs text-emerald-600 font-medium">attivo</span> }
                                else { <span class="text-xs text-slate-400">disattivo</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm h-fit">
        <h2 class="font-semibold text-slate-900 mb-4">Nuovo utente</h2>
        @if (_err is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_err</div> }
        <div class="space-y-3">
            <input @bind="_email" placeholder="Email" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <input @bind="_fullName" placeholder="Nome completo" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <input @bind="_password" type="password" placeholder="Password (min 8)" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <select @bind="_role" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="Agent">Agent (operatore)</option>
                <option value="Client">Client (cliente)</option>
                <option value="Admin">Admin</option>
            </select>
            @if (_role == "Client")
            {
                <select @bind="_companyId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                    <option value="">— azienda —</option>
                    @foreach (var c in _companies) { <option value="@c.Id">@c.Name</option> }
                </select>
            }
            <button @onclick="Create" class="w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Crea</button>
        </div>
    </div>
</div>

@code {
    private List<AppUserRow> _items = new();
    private List<Company> _companies = new();
    private string _email = ""; private string? _fullName; private string _password = "";
    private string _role = "Agent"; private string _companyId = ""; private string? _err;

    protected override async Task OnInitializedAsync()
    {
        try { _companies = await Api.GetCompaniesAsync(); } catch { }
        await Load();
    }
    private async Task Load() { try { _items = await Api.GetUsersAsync(); } catch { } }

    private async Task Create()
    {
        _err = null;
        if (string.IsNullOrWhiteSpace(_email) || _password.Length < 8) { _err = "Email e password (min 8) obbligatorie."; return; }
        int? co = _role == "Client" && int.TryParse(_companyId, out var c) ? c : null;
        if (_role == "Client" && co is null) { _err = "Seleziona un'azienda per il Client."; return; }

        var resp = await Api.CreateUserAsync(new CreateUserRequest(_email.Trim(), _password, _role, _fullName, co));
        if (!resp.IsSuccessStatusCode) { _err = $"Errore ({(int)resp.StatusCode})."; return; }
        _email = ""; _fullName = null; _password = ""; _companyId = ""; await Load();
    }
}
