@model Aski.Shared.ProvisioningStatus
@{
    var (cls, label) = Model switch
    {
        ProvisioningStatus.Running => ("bg-emerald-100 text-emerald-700", "Running"),
        ProvisioningStatus.Provisioning => ("bg-blue-100 text-blue-700", "Provisioning"),
        ProvisioningStatus.Stopped => ("bg-slate-100 text-slate-600", "Stopped"),
        ProvisioningStatus.Failed => ("bg-rose-100 text-rose-700", "Failed"),
        _ => ("bg-slate-100 text-slate-500", "Non provisionato")
    };
}
<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @cls">@label</span>
