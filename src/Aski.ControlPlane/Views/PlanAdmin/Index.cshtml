@model PlansViewModel
@{
    string Money(long cents, string cur) => $"{cents / 100m:0.00} {cur.ToUpperInvariant()}";
}

@if (!Model.StripeConfigured)
{
    <div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
        ⚠️ Configura prima Stripe: la creazione di un piano sincronizza Product e Price.
        <a href="/StripeAdmin" class="font-medium underline">Vai a Stripe</a>
    </div>
}

<div class="grid lg:grid-cols-3 gap-6">
    <!-- Lista -->
    <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200">
            <h2 class="font-semibold text-slate-900">Piani (@Model.Plans.Count)</h2>
        </div>
        @if (Model.Plans.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun piano. Creane uno →</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr>
                        <th class="px-5 py-3 font-medium">Nome</th>
                        <th class="px-5 py-3 font-medium">Prezzo</th>
                        <th class="px-5 py-3 font-medium">Periodo</th>
                        <th class="px-5 py-3 font-medium">Stripe</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var p in Model.Plans)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3 font-medium text-slate-900">@p.Name</td>
                            <td class="px-5 py-3 text-slate-700">@Money(p.Amount, p.Currency)</td>
                            <td class="px-5 py-3 text-slate-600">@(p.Period == BillingPeriod.Monthly ? "Mensile" : "Annuale")</td>
                            <td class="px-5 py-3">
                                @if (p.StripePriceId is not null)
                                {
                                    <span class="font-mono text-xs text-slate-500">@p.StripePriceId</span>
                                }
                                else
                                {
                                    <span class="text-xs text-rose-600">non sincronizzato</span>
                                }
                            </td>
                            <td class="px-5 py-3 text-right">
                                <form asp-action="Sync" method="post" class="inline">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button class="text-xs text-indigo-600 hover:underline">Sincronizza</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Form -->
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm h-fit">
        <h2 class="font-semibold text-slate-900 mb-4">Nuovo piano</h2>
        <form asp-action="Create" method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700">Nome</label>
                <input name="Name" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Descrizione</label>
                <input name="Description" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Prezzo</label>
                    <input name="Price" type="number" step="0.01" min="0" required placeholder="19.99" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Valuta</label>
                    <input name="Currency" value="eur" maxlength="3" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm uppercase focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Periodo</label>
                <select name="Period" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                    <option value="0">Mensile</option>
                    <option value="1">Annuale</option>
                </select>
            </div>
            <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Crea e sincronizza</button>
        </form>
    </div>
</div>
