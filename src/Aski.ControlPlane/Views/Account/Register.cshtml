@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Crea il tuo account";
}
<h1 class="text-xl font-bold text-slate-900 mb-1">Crea il tuo account</h1>
<p class="text-sm text-slate-500 mb-6">Registra la tua azienda e inizia subito a creare i tuoi portali di assistenza.</p>

<form asp-action="Register" method="post" class="space-y-4">
    <div>
        <label class="block text-sm font-medium text-slate-700">Nome azienda</label>
        <input name="CompanyName" required autofocus placeholder="Acme Srl" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700">Email</label>
        <input name="Email" type="email" required placeholder="tu@acme.it" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700">Password</label>
        <input name="Password" type="password" required minlength="8" placeholder="Minimo 8 caratteri" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
    </div>
    <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Crea account</button>
</form>

<p class="mt-6 text-center text-sm text-slate-500">
    Hai già un account?
    <a asp-action="Login" class="font-medium text-indigo-600 hover:underline">Accedi</a>
</p>
