@page "/tickets/new"
@page "/tickets/{Id:int}/edit"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<AppTitle Suffix="@(_isEdit ? "Modifica ticket" : "Nuovo ticket")" />

<div class="mb-6">
    <button @onclick="Back" class="text-sm text-slate-500 hover:text-slate-700">← Ticket</button>
    <h1 class="text-2xl font-bold tracking-tight text-slate-900 mt-2">@(_isEdit ? "Modifica ticket" : "Nuovo ticket")</h1>
    <p class="text-sm text-slate-500">@(_isEdit ? "Aggiorna i dati del ticket." : "Apri una nuova richiesta di assistenza.")</p>
</div>

<div class="rounded-xl border border-slate-200 bg-white shadow-sm p-6">
    @if (_error is not null) { <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_error</div> }
    <div class="space-y-4">
        <Field Label="Titolo *"><input @bind="_title" class="@Inp" /></Field>
        <Field Label="Descrizione"><textarea @bind="_desc" rows="12" class="@Inp"></textarea></Field>
        <div class="grid gap-4 md:grid-cols-4">
            <Field Label="Priorità">
                <select @bind="_priority" class="@Inp">
                    <option value="0">Bassa</option><option value="1">Normale</option><option value="2">Alta</option><option value="3">Urgente</option>
                </select>
            </Field>
            @if (_isAdmin)
            {
                <Field Label="Azienda *">
                    <select @bind="_companyId" @bind:after="OnCompanyChanged" class="@Inp">
                        <option value="">— seleziona —</option>
                        @foreach (var c in _companies) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </Field>
            }
            <Field Label="Software">
                <select @bind="_softwareId" @bind:after="OnSoftwareChanged" class="@Inp">
                    <option value="">—</option>
                    @foreach (var s in _software) { <option value="@s.Id">@s.Name</option> }
                </select>
            </Field>
            @if (_versions.Count > 0)
            {
                <Field Label="Versione">
                    <select @bind="_versionId" class="@Inp">
                        <option value="">—</option>
                        @foreach (var v in _versions) { <option value="@v.Id">v@(v.Version)</option> }
                    </select>
                </Field>
            }
        </div>

        <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Allegati</label>
            <label class="cursor-pointer inline-block rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50">
                + Aggiungi file
                <InputFile OnChange="OnFilesSelected" multiple class="hidden" />
            </label>
            @if (_files.Count > 0)
            {
                <ul class="mt-2 space-y-1">
                    @foreach (var f in _files)
                    {
                        <li class="flex items-center justify-between text-sm rounded-lg border border-slate-200 px-3 py-1.5">
                            <span class="text-slate-700">@f.Name</span>
                            <button type="button" @onclick="() => RemoveFile(f)" class="text-xs text-rose-600 hover:underline">Rimuovi</button>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
    <div class="mt-6 flex items-center justify-end gap-2">
        <button @onclick="Back" class="@BtnGhost">Annulla</button>
        <button @onclick="Save" disabled="@_saving" class="@BtnPrimary">@(_saving ? "Salvataggio…" : _isEdit ? "Salva modifiche" : "Crea ticket")</button>
    </div>
</div>

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700 disabled:opacity-50";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    [Parameter] public int Id { get; set; }
    private bool _isEdit => Id > 0;

    private List<Software> _software = new();
    private List<Company> _companies = new();
    private List<SoftwareVersion> _versions = new();
    private bool _isAdmin, _saving;
    private string _title = ""; private string? _desc; private int _priority = 1;
    private string _softwareId = ""; private string _versionId = ""; private string _companyId = ""; private string? _error;
    private List<IBrowserFile> _files = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _isAdmin = auth.User.IsInRole("Admin");
        try
        {
            if (_isAdmin) _companies = await Api.GetCompaniesAsync();
            else _software = await Api.GetSoftwareAsync();
        }
        catch { }

        if (_isEdit)
        {
            var t = await Api.GetTicketAsync(Id);
            if (t is null) { _error = "Ticket non trovato."; return; }
            _title = t.Title; _desc = t.Description; _priority = (int)t.Priority;
            _companyId = t.CompanyId.ToString();
            if (_isAdmin) await OnCompanyChanged();
            _softwareId = t.SoftwareId?.ToString() ?? "";
            if (!string.IsNullOrEmpty(_softwareId)) await LoadVersions();
            _versionId = t.SoftwareVersionId?.ToString() ?? "";
        }
    }

    private async Task LoadVersions()
    {
        _versions = new();
        if (int.TryParse(_softwareId, out var sid))
        {
            try { _versions = (await Api.GetVersionsAsync(sid)).Where(v => v.IsActive).ToList(); } catch { }
        }
    }

    private async Task OnSoftwareChanged()
    {
        _versionId = "";
        await LoadVersions();
    }

    private async Task OnCompanyChanged()
    {
        _software = new(); _softwareId = ""; _versions = new(); _versionId = "";
        if (int.TryParse(_companyId, out var cid))
        {
            var all = await Api.GetSoftwareAsync();
            var company = _companies.FirstOrDefault(c => c.Id == cid);
            _software = company is null ? all : all.Where(s => company.SoftwareIds.Contains(s.Id)).ToList();
        }
    }

    private void Back() => Nav.NavigateTo(_isEdit ? $"tickets/{Id}" : "tickets");

    private void OnFilesSelected(InputFileChangeEventArgs e) => _files.AddRange(e.GetMultipleFiles(20));
    private void RemoveFile(IBrowserFile f) => _files.Remove(f);

    private async Task UploadFilesAsync(int ticketId)
    {
        foreach (var f in _files)
        {
            try
            {
                using var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(f.OpenReadStream(20 * 1024 * 1024));
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                    string.IsNullOrWhiteSpace(f.ContentType) ? "application/octet-stream" : f.ContentType);
                content.Add(fileContent, "file", f.Name);
                await Api.UploadAttachmentAsync(ticketId, content);
            }
            catch { }
        }
    }

    private async Task Save()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_title)) { _error = "Titolo obbligatorio."; return; }
        int? sw = int.TryParse(_softwareId, out var s) ? s : null;
        int? ver = int.TryParse(_versionId, out var v) ? v : null;
        int? co = _isAdmin && int.TryParse(_companyId, out var c) ? c : null;
        if (_isAdmin && co is null) { _error = "Seleziona un'azienda."; return; }

        _saving = true;
        var req = new CreateTicketRequest(_title.Trim(), _desc, sw, ver, (TicketPriority)_priority, co);
        if (_isEdit)
        {
            var resp = await Api.UpdateTicketAsync(Id, req);
            if (!resp.IsSuccessStatusCode) { _saving = false; _error = $"Errore ({(int)resp.StatusCode})."; return; }
            if (_files.Count > 0) await UploadFilesAsync(Id);
            _saving = false;
            Nav.NavigateTo($"tickets/{Id}");
        }
        else
        {
            var resp = await Api.CreateTicketAsync(req);
            if (!resp.IsSuccessStatusCode) { _saving = false; _error = $"Errore ({(int)resp.StatusCode})."; return; }
            var created = await resp.Content.ReadFromJsonAsync<CreatedTicket>();
            if (created is not null && _files.Count > 0) await UploadFilesAsync(created.Id);
            _saving = false;
            Nav.NavigateTo(created is not null ? $"tickets/{created.Id}" : "tickets");
        }
    }
}
