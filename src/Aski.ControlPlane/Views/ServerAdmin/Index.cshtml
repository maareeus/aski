@model ServersViewModel

<div class="grid lg:grid-cols-3 gap-6">
    <!-- Lista -->
    <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200">
            <h2 class="font-semibold text-slate-900">Server (@Model.Servers.Count)</h2>
        </div>
        @if (Model.Servers.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun server. Creane uno →</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr>
                        <th class="px-5 py-3 font-medium">Nome</th>
                        <th class="px-5 py-3 font-medium">Regione</th>
                        <th class="px-5 py-3 font-medium">Tipo</th>
                        <th class="px-5 py-3 font-medium">N / container</th>
                        <th class="px-5 py-3 font-medium">Container</th>
                        <th class="px-5 py-3 font-medium">Stato</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var s in Model.Servers)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3 font-medium text-slate-900">@s.Name</td>
                            <td class="px-5 py-3 text-slate-600">@s.Region</td>
                            <td class="px-5 py-3 text-slate-600">@(s.Type == ServerType.VpsDocker ? "VPS Docker" : "AWS ECS")</td>
                            <td class="px-5 py-3 text-slate-600">@s.MaxProjectsPerDbContainer</td>
                            <td class="px-5 py-3 text-slate-600">@s.DbContainers.Count</td>
                            <td class="px-5 py-3">
                                @if (s.IsEnabled)
                                {
                                    <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Abilitato</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-500">Disabilitato</span>
                                }
                            </td>
                            <td class="px-5 py-3 text-right">
                                <form asp-action="Toggle" method="post" class="inline">
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button class="text-xs text-indigo-600 hover:underline">@(s.IsEnabled ? "Disabilita" : "Abilita")</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Form -->
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm h-fit">
        <h2 class="font-semibold text-slate-900 mb-4">Nuovo server</h2>
        <form asp-action="Create" method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700">Nome</label>
                <input name="Name" required placeholder="EU Milano" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Regione</label>
                <input name="Region" required placeholder="it-mil-1" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Tipo</label>
                <select name="Type" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                    <option value="0">VPS Docker</option>
                    <option value="1">AWS ECS (stub)</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Hostname</label>
                <input name="Hostname" placeholder="10.0.0.5" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Config JSON</label>
                <textarea name="ConfigJson" rows="4" placeholder='{"dockerHost":"tcp://10.0.0.5:2376","network":"traefik","domainSuffix":"aski.app"}'
                          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-xs font-mono focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"></textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Limite N (progetti per container Postgres)</label>
                <input name="MaxProjectsPerDbContainer" type="number" min="1" value="10" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <label class="flex items-center gap-2 text-sm text-slate-700">
                <input type="checkbox" name="IsEnabled" value="true" checked class="rounded border-slate-300" /> Abilitato
            </label>
            <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Crea server</button>
        </form>
    </div>
</div>
