@page "/users/{Id}"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api
@inject NavigationManager Nav

<AppTitle Suffix="@(_u is null ? "Utente" : (string.IsNullOrWhiteSpace(_u.Display) ? _u.Email : _u.Display))" />

<a href="users" class="text-sm text-slate-500 hover:text-slate-700">← Utenti</a>

@if (_u is null)
{
    <p class="mt-4 text-sm text-slate-400">Caricamento…</p>
}
else
{
    <div class="mt-3 flex items-start justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">@(string.IsNullOrWhiteSpace(_u.Display) ? _u.Email : _u.Display)</h1>
            <div class="mt-2 flex items-center gap-2 text-sm">
                <span class="text-slate-500">@string.Join(", ", _u.Roles)</span>
                @if (_u.IsActive) { <span class="rounded-full bg-emerald-100 text-emerald-700 px-2 py-0.5 text-xs font-medium">Attivo</span> }
                else { <span class="rounded-full bg-slate-100 text-slate-500 px-2 py-0.5 text-xs font-medium">Disattivo</span> }
            </div>
        </div>
        <button @onclick="OpenEdit" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Modifica</button>
    </div>

    @if (_msg is not null) { <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700">@_msg</div> }

    <div class="mt-6 grid lg:grid-cols-4 gap-6">
        <div class="lg:col-span-3 space-y-6">
            <!-- Info -->
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Anagrafica</h2>
                <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
                    <div><dt class="text-slate-400">Email</dt><dd class="text-slate-700">@_u.Email</dd></div>
                    <div><dt class="text-slate-400">Telefono</dt><dd class="text-slate-700">@(_u.Phone ?? "—")</dd></div>
                    <div><dt class="text-slate-400">Nome</dt><dd class="text-slate-700">@(_u.FirstName ?? "—")</dd></div>
                    <div><dt class="text-slate-400">Cognome</dt><dd class="text-slate-700">@(_u.LastName ?? "—")</dd></div>
                    <div><dt class="text-slate-400">Ruolo in azienda</dt><dd class="text-slate-700">@(_u.JobTitle ?? "—")</dd></div>
                </dl>
            </div>

            <!-- Software -->
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="font-semibold text-slate-900">Software di competenza (@_u.SoftwareIds.Count)</h2>
                    <button @onclick="OpenSoftware" class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50">Gestisci</button>
                </div>
                @if (_u.SoftwareIds.Count == 0)
                {
                    <p class="text-sm text-slate-400">Nessun software assegnato.</p>
                }
                else
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var s in _allSoftware.Where(s => _u.SoftwareIds.Contains(s.Id)))
                        {
                            <span class="rounded-full bg-indigo-50 text-indigo-700 px-3 py-1 text-xs font-medium">@s.Name</span>
                        }
                    </div>
                }
            </div>

            <!-- Ticket assegnati -->
            <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-x-auto">
                <div class="px-5 py-4 border-b border-slate-200"><h2 class="font-semibold text-slate-900">Ticket assegnati (@_assigned.Count)</h2></div>
                @if (_assigned.Count == 0) { <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun ticket assegnato.</p> }
                else { @TicketTable(_assigned) }
            </div>

            <!-- Ticket visibili -->
            <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-x-auto">
                <div class="px-5 py-4 border-b border-slate-200"><h2 class="font-semibold text-slate-900">Ticket visibili (@_visible.Count)</h2></div>
                @if (_visible.Count == 0) { <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun ticket visibile.</p> }
                else { @TicketTable(_visible) }
            </div>
        </div>

        <div class="space-y-6">
            <!-- Unit -->
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Unit (@_units.Count)</h2>
                @if (_units.Count == 0) { <p class="text-sm text-slate-400">Nessuna unit.</p> }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var u in _units)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <span class="text-slate-700">@u.Name</span>
                                @if (u.IsManager) { <span class="rounded-full bg-amber-100 text-amber-700 px-2 py-0.5 text-xs font-medium">PM</span> }
                            </li>
                        }
                    </ul>
                }
            </div>

            <!-- Azioni -->
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Sicurezza</h2>
                <button @onclick="OpenReset" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Reset password</button>
                @if (_u.IsActive)
                {
                    <button @onclick="() => SetActive(false)" class="mt-2 w-full rounded-lg border border-rose-300 px-3 py-2 text-sm font-medium text-rose-600 hover:bg-rose-50">Disabilita utente</button>
                }
                else
                {
                    <button @onclick="() => SetActive(true)" class="mt-2 w-full rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700">Riabilita utente</button>
                }
            </div>
        </div>
    </div>

    <!-- Modifica anagrafica -->
    <Modal Visible="_showEdit" Title="Modifica utente" MaxWidth="max-w-xl" OnClose="() => _showEdit = false">
        <div class="grid grid-cols-2 gap-3">
            <Field Label="Nome"><input @bind="_first" class="@Inp" /></Field>
            <Field Label="Cognome"><input @bind="_last" class="@Inp" /></Field>
            <Field Label="Ruolo in azienda"><input @bind="_job" class="@Inp" /></Field>
            <Field Label="Telefono"><input @bind="_phone" class="@Inp" /></Field>
        </div>
        <div class="mt-5 flex items-center justify-end gap-2">
            <button @onclick="() => _showEdit = false" class="@BtnGhost">Annulla</button>
            <button @onclick="SaveEdit" class="@BtnPrimary">Salva</button>
        </div>
    </Modal>

    <!-- Software -->
    <Modal Visible="_showSoftware" Title="Software di competenza" OnClose="() => _showSoftware = false">
        <div class="space-y-2 max-h-80 overflow-y-auto">
            @foreach (var s in _allSoftware)
            {
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" checked="@_sel.Contains(s.Id)" @onchange="e => Toggle(s.Id, e)" class="rounded border-slate-300" />
                    <span class="text-slate-700">@s.Name</span>
                </label>
            }
        </div>
        <div class="mt-5 flex items-center justify-end gap-2">
            <button @onclick="() => _showSoftware = false" class="@BtnGhost">Annulla</button>
            <button @onclick="SaveSoftware" class="@BtnPrimary">Salva</button>
        </div>
    </Modal>

    <!-- Reset password -->
    <Modal Visible="_showReset" Title="Reset password" OnClose="() => _showReset = false">
        @if (_resetErr is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_resetErr</div> }
        <Field Label="Nuova password (min 8)"><input @bind="_newPwd" type="password" class="@Inp" /></Field>
        <div class="mt-5 flex items-center justify-end gap-2">
            <button @onclick="() => _showReset = false" class="@BtnGhost">Annulla</button>
            <button @onclick="DoReset" class="@BtnPrimary">Reimposta</button>
        </div>
    </Modal>
}

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    [Parameter] public string Id { get; set; } = "";
    private AppUserRow? _u;
    private List<Software> _allSoftware = new();
    private List<UserUnit> _units = new();
    private List<UserTicket> _assigned = new();
    private List<UserTicket> _visible = new();
    private string? _msg;

    private bool _showEdit, _showSoftware, _showReset;
    private string? _first, _last, _job, _phone;
    private HashSet<int> _sel = new();
    private string _newPwd = ""; private string? _resetErr;

    protected override async Task OnInitializedAsync()
    {
        try { _allSoftware = await Api.GetSoftwareAsync(); } catch { }
        await Load();
    }

    private async Task Load()
    {
        try
        {
            _u = await Api.GetUserAsync(Id);
            _units = await Api.GetUserUnitsAsync(Id);
            _assigned = await Api.GetUserAssignedTicketsAsync(Id);
            _visible = await Api.GetUserVisibleTicketsAsync(Id);
        }
        catch { _u = null; }
    }

    private RenderFragment TicketTable(List<UserTicket> list) => __builder =>
    {
        <table class="w-full text-sm">
            <thead class="text-left text-slate-500 border-b border-slate-100">
                <tr><th class="px-5 py-2 font-medium">Numero</th><th class="px-5 py-2 font-medium">Titolo</th>
                    <th class="px-5 py-2 font-medium">Cliente</th><th class="px-5 py-2 font-medium">Stato</th></tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var t in list)
                {
                    <tr class="hover:bg-slate-50 cursor-pointer" @onclick="() => Open(t.Id)">
                        <td class="px-5 py-2 font-mono text-xs text-indigo-600">@(t.Number ?? $"#{t.Id}")</td>
                        <td class="px-5 py-2 font-medium text-slate-900">@t.Title</td>
                        <td class="px-5 py-2 text-slate-600">@(t.CompanyName ?? "—")</td>
                        <td class="px-5 py-2"><StatusBadge Status="t.Status" /></td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private void Open(int id) => Nav.NavigateTo($"tickets/{id}");
    private void Toggle(int id, ChangeEventArgs e) { if ((bool)e.Value!) _sel.Add(id); else _sel.Remove(id); }

    private void OpenEdit()
    {
        _first = _u!.FirstName; _last = _u.LastName; _job = _u.JobTitle; _phone = _u.Phone; _showEdit = true;
    }

    private async Task SaveEdit()
    {
        await Api.UpdateUserAsync(Id, new UpdateUserRequest(_first, _last, _job, _phone, null));
        _showEdit = false; _msg = "Anagrafica aggiornata."; await Load();
    }

    private void OpenSoftware() { _sel = new HashSet<int>(_u!.SoftwareIds); _showSoftware = true; }

    private async Task SaveSoftware()
    {
        await Api.SetUserSoftwareAsync(Id, _sel.ToList());
        _showSoftware = false; _msg = "Software aggiornati."; await Load();
    }

    private void OpenReset() { _newPwd = ""; _resetErr = null; _showReset = true; }

    private async Task DoReset()
    {
        _resetErr = null;
        if (_newPwd.Length < 8) { _resetErr = "Password minimo 8 caratteri."; return; }
        var r = await Api.ResetPasswordAsync(Id, _newPwd);
        if (!r.IsSuccessStatusCode) { _resetErr = $"Errore ({(int)r.StatusCode})."; return; }
        _showReset = false; _msg = "Password reimpostata.";
    }

    private async Task SetActive(bool enabled)
    {
        var r = await Api.SetUserActiveAsync(Id, enabled);
        _msg = r.IsSuccessStatusCode ? (enabled ? "Utente riabilitato." : "Utente disabilitato.") : "Errore.";
        await Load();
    }
}
