@page "/software/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api

<a href="software" class="text-sm text-slate-500 hover:text-slate-700">← Software</a>

@if (_sw is null)
{
    <p class="mt-4 text-sm text-slate-400">Caricamento…</p>
}
else
{
    <div class="mt-3 flex items-start justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">@_sw.Name</h1>
            <p class="text-sm text-slate-500 mt-1">@(_sw.Description ?? "—")</p>
        </div>
        <button @onclick="OpenEdit" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Modifica</button>
    </div>

    <div class="mt-6 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">Versioni (@_versions.Count)</h2>
            <button @onclick="OpenAddVersion" class="rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-700">Nuova versione</button>
        </div>
        @if (_versions.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessuna versione. Aggiungi la prima.</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr><th class="px-5 py-3 font-medium">Versione</th><th class="px-5 py-3 font-medium">Stato</th>
                        <th class="px-5 py-3 font-medium">Rilascio</th>
                        <th class="px-5 py-3 font-medium">Note</th><th class="px-5 py-3 font-medium">Inserita</th><th class="px-5 py-3"></th></tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var v in _versions)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3"><span class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">v@(v.Version)</span></td>
                            <td class="px-5 py-3">
                                @if (v.IsActive) { <span class="rounded-full bg-emerald-100 text-emerald-700 px-2 py-0.5 text-xs font-medium">Attiva</span> }
                                else { <span class="rounded-full bg-slate-200 text-slate-500 px-2 py-0.5 text-xs font-medium">Obsoleta</span> }
                            </td>
                            <td class="px-5 py-3 text-slate-600">@(v.ReleasedAtUtc?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="px-5 py-3 text-slate-500">@(v.Notes ?? "—")</td>
                            <td class="px-5 py-3 text-slate-400">@v.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td class="px-5 py-3 text-right space-x-3">
                                @if (v.IsActive) { <button @onclick="() => SetActive(v.Id, false)" class="text-xs text-amber-600 hover:underline">Obsoleta</button> }
                                else { <button @onclick="() => SetActive(v.Id, true)" class="text-xs text-emerald-600 hover:underline">Riattiva</button> }
                                <button @onclick="() => OpenEditVersion(v)" class="text-xs text-indigo-600 hover:underline">Modifica</button>
                                <button @onclick="() => DeleteVersion(v.Id)" class="text-xs text-rose-600 hover:underline">Elimina</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

<!-- Modal versione (nuova/modifica) -->
<Modal Visible="_showVersion" Title="@(_editVersionId is null ? "Nuova versione" : "Modifica versione")" OnClose="() => _showVersion = false">
    @if (_err is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_err</div> }
    <div class="space-y-3">
        <Field Label="Versione *"><input @bind="_version" placeholder="es. 1.2.0" class="@Inp" /></Field>
        <Field Label="Data rilascio"><input @bind="_released" type="date" class="@Inp" /></Field>
        <Field Label="Note interne"><textarea @bind="_notes" rows="2" class="@Inp"></textarea></Field>
        <Field Label="Note di rilascio (Markdown, visibili ai clienti)"><textarea @bind="_releaseNotes" rows="6" placeholder="# Novità&#10;- ..." class="@Inp font-mono text-xs"></textarea></Field>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showVersion = false" class="@BtnGhost">Annulla</button>
        <button @onclick="SaveVersion" class="@BtnPrimary">@(_editVersionId is null ? "Aggiungi" : "Salva")</button>
    </div>
</Modal>

<!-- Modal modifica software -->
<Modal Visible="_showEdit" Title="Modifica software" OnClose="() => _showEdit = false">
    <div class="space-y-3">
        <Field Label="Nome *"><input @bind="_name" class="@Inp" /></Field>
        <Field Label="Descrizione"><textarea @bind="_desc" rows="2" class="@Inp"></textarea></Field>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showEdit = false" class="@BtnGhost">Annulla</button>
        <button @onclick="SaveEdit" class="@BtnPrimary">Salva</button>
    </div>
</Modal>

@code {
    [Parameter] public int Id { get; set; }
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    private SoftwareDetail? _sw;
    private List<SoftwareVersion> _versions = new();

    private bool _showVersion, _showEdit;
    private int? _editVersionId;
    private string _version = ""; private string? _notes; private string? _releaseNotes; private DateTime? _released; private string? _err;
    private string _name = ""; private string? _desc;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try { _sw = await Api.GetSoftwareDetailAsync(Id); _versions = await Api.GetVersionsAsync(Id); }
        catch { _sw = null; }
    }

    private void OpenAddVersion() { _editVersionId = null; _version = ""; _notes = null; _releaseNotes = null; _released = null; _err = null; _showVersion = true; }

    private void OpenEditVersion(SoftwareVersion v)
    {
        _editVersionId = v.Id; _version = v.Version; _notes = v.Notes; _releaseNotes = v.ReleaseNotes;
        _released = v.ReleasedAtUtc?.ToLocalTime(); _err = null; _showVersion = true;
    }

    private async Task SaveVersion()
    {
        _err = null;
        if (string.IsNullOrWhiteSpace(_version)) { _err = "Versione obbligatoria."; return; }
        var req = new CreateVersionRequest(_version.Trim(), _notes, _releaseNotes, _released?.ToUniversalTime());
        var resp = _editVersionId is null
            ? await Api.AddVersionAsync(Id, req)
            : await Api.UpdateVersionAsync(Id, _editVersionId.Value, req);
        if (!resp.IsSuccessStatusCode) { _err = $"Errore ({(int)resp.StatusCode})."; return; }
        _showVersion = false; await Load();
    }

    private async Task DeleteVersion(int versionId)
    {
        await Api.DeleteVersionAsync(Id, versionId);
        await Load();
    }

    private async Task SetActive(int versionId, bool enabled)
    {
        await Api.SetVersionActiveAsync(Id, versionId, enabled);
        await Load();
    }

    private void OpenEdit() { _name = _sw!.Name; _desc = _sw.Description; _showEdit = true; }

    private async Task SaveEdit()
    {
        await Api.UpdateSoftwareAsync(Id, new CreateSoftwareRequest(_name.Trim(), _desc));
        _showEdit = false; await Load();
    }
}

