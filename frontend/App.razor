@using Aski.Tickets.Web.Pages
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <LayoutView Layout="@typeof(MainLayout)">
                            <div class="p-8 text-center text-slate-500">Non hai i permessi per questa pagina.</div>
                        </LayoutView>
                    }
                </NotAuthorized>
                <Authorizing>
                    <div class="p-8 text-center text-slate-400">Verifica accesso…</div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="p-8 text-center text-slate-500">Pagina non trovata.</div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
