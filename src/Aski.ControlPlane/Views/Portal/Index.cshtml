@model TenantDetailViewModel
@{
    var t = Model.Tenant;
    string Money(long cents, string cur) => $"{cents / 100m:0.00} {cur.ToUpperInvariant()}";
}

<!-- Header org -->
<div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm flex flex-wrap items-center gap-6">
    <div class="h-12 w-12 rounded-xl bg-indigo-600 flex items-center justify-center text-white text-lg font-bold">
        @(t.CompanyName.Length > 0 ? t.CompanyName[..1].ToUpper() : "?")
    </div>
    <div>
        <h2 class="text-lg font-bold text-slate-900">@t.CompanyName</h2>
        <p class="text-sm text-slate-500">@t.BillingEmail</p>
    </div>
    <div class="ml-auto">
        @if (t.StripeCustomerId is not null)
        {
            <form asp-action="Billing" method="post">
                <button class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Gestisci fatturazione</button>
            </form>
        }
        else
        {
            <span class="text-xs text-slate-400">Nessun abbonamento ancora attivo</span>
        }
    </div>
</div>

<div class="mt-6 grid lg:grid-cols-2 gap-6">
    <!-- Abbonamenti -->
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200"><h3 class="font-semibold text-slate-900">Abbonamenti</h3></div>
        @if (t.Subscriptions.Count == 0)
        {
            <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun abbonamento. Scegli un piano →</p>
        }
        else
        {
            <ul class="divide-y divide-slate-100">
                @foreach (var s in t.Subscriptions)
                {
                    <li class="px-5 py-3 flex items-center justify-between">
                        <div>
                            <p class="font-medium text-slate-900">@(s.Plan?.Name ?? "Piano")</p>
                            <p class="text-xs text-slate-500">@(s.StripeSubscriptionId ?? "—")</p>
                        </div>
                        <partial name="_SubscriptionBadge" model="s.Status" />
                    </li>
                }
            </ul>
        }
    </div>

    <!-- Piani disponibili (info) -->
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200"><h3 class="font-semibold text-slate-900">Piani disponibili</h3></div>
        @if (Model.AvailablePlans.Count == 0)
        {
            <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun piano disponibile al momento.</p>
        }
        else
        {
            <ul class="divide-y divide-slate-100">
                @foreach (var p in Model.AvailablePlans)
                {
                    <li class="px-5 py-3 flex items-center justify-between">
                        <p class="font-medium text-slate-900">@p.Name</p>
                        <p class="text-xs text-slate-500">@Money(p.Amount, p.Currency) / @(p.Period == BillingPeriod.Monthly ? "mese" : "anno")</p>
                    </li>
                }
            </ul>
            <p class="px-5 py-3 text-xs text-slate-400 border-t border-slate-100">Attiva un piano dal singolo progetto, qui sotto.</p>
        }
    </div>
</div>

<!-- Progetti -->
<div class="mt-6 grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200"><h3 class="font-semibold text-slate-900">I tuoi progetti</h3></div>
        @if (t.Projects.Count == 0)
        {
            <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun progetto. Creane uno →</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr>
                        <th class="px-5 py-3 font-medium">Nome</th>
                        <th class="px-5 py-3 font-medium">Server</th>
                        <th class="px-5 py-3 font-medium">Dominio</th>
                        <th class="px-5 py-3 font-medium">Stato</th>
                        <th class="px-5 py-3 font-medium">Attivazione</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var p in t.Projects)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3 font-medium text-slate-900">@p.Name</td>
                            <td class="px-5 py-3 text-slate-600">@(p.Server?.Name ?? "—")</td>
                            <td class="px-5 py-3 text-slate-600">@(p.Subdomain ?? p.CustomDomain ?? "—")</td>
                            <td class="px-5 py-3"><partial name="_ProvisioningBadge" model="p.ProvisioningStatus" /></td>
                            <td class="px-5 py-3">
                                @if (p.SubscriptionId is not null)
                                {
                                    <span class="text-xs text-emerald-600 font-medium">Piano attivo</span>
                                }
                                else if (Model.AvailablePlans.Count > 0)
                                {
                                    <form asp-action="Checkout" method="post" class="flex items-center gap-2">
                                        <input type="hidden" name="projectId" value="@p.Id" />
                                        <select name="planId" class="rounded-lg border border-slate-300 px-2 py-1 text-xs">
                                            @foreach (var pl in Model.AvailablePlans)
                                            {
                                                <option value="@pl.Id">@pl.Name</option>
                                            }
                                        </select>
                                        <button class="rounded-lg bg-indigo-600 px-3 py-1 text-xs font-semibold text-white hover:bg-indigo-700">Attiva</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400">Nessun piano</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Nuovo progetto -->
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm h-fit">
        <h3 class="font-semibold text-slate-900 mb-4">Nuovo progetto</h3>
        @if (Model.EnabledServers.Count == 0)
        {
            <p class="text-sm text-slate-400">Nessun server disponibile al momento. Riprova più tardi.</p>
        }
        else
        {
            <form asp-action="CreateProject" method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700">Nome</label>
                    <input name="ProjectName" required placeholder="Supporto" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Server / Regione</label>
                    <select name="ServerId" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                        @foreach (var s in Model.EnabledServers)
                        {
                            <option value="@s.Id">@s.Name (@s.Region)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Sottodominio</label>
                    <input name="Subdomain" placeholder="acme" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700">Dominio personalizzato</label>
                    <input name="CustomDomain" placeholder="support.acme.com" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                </div>
                <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Crea progetto</button>
            </form>
        }
    </div>
</div>
