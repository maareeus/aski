@page "/tickets/{Id:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient Api
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS

<a href="tickets" class="text-sm text-slate-500 hover:text-slate-700">← Ticket</a>

@if (_loading)
{
    <p class="mt-4 text-sm text-slate-400">Caricamento…</p>
}
else if (_t is null)
{
    <p class="mt-4 text-sm text-rose-600">Ticket non trovato o accesso negato.</p>
}
else
{
    <div class="mt-3">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">@_t.Title</h1>
        <div class="mt-2 flex items-center gap-2">
            <span class="font-mono text-xs text-indigo-600">@(_t.Number ?? $"#{_t.Id}")</span>
            <StatusBadge Status="_t.Status" />
            <PriorityBadge Priority="_t.Priority" />
            @if (_t.CompanyName is not null) { <span class="text-slate-400 text-sm">• @_t.CompanyName</span> }
        </div>
    </div>

    <div class="mt-6 grid lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-1">Descrizione</h2>
                <p class="text-sm text-slate-600 whitespace-pre-wrap">@(_t.Description ?? "—")</p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="font-semibold text-slate-900">Allegati</h2>
                    <label class="cursor-pointer rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50">
                        @(_uploading ? "Caricamento…" : "+ Allega file")
                        <InputFile OnChange="OnFileSelected" class="hidden" disabled="@_uploading" />
                    </label>
                </div>
                @if (_t.Attachments.Count == 0)
                {
                    <p class="text-sm text-slate-400">Nessun allegato.</p>
                }
                else
                {
                    <ul class="divide-y divide-slate-100">
                        @foreach (var a in _t.Attachments)
                        {
                            <li class="flex items-center justify-between py-2 text-sm">
                                <div>
                                    <span class="font-medium text-slate-700">@a.FileName</span>
                                    <span class="text-slate-400 text-xs ml-2">@FmtSize(a.Size)</span>
                                </div>
                                <button @onclick="() => Download(a)" class="text-indigo-600 hover:text-indigo-800 font-medium">Scarica</button>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="px-5 py-4 border-b border-slate-200"><h2 class="font-semibold text-slate-900">Conversazione</h2></div>
                @if (_t.Comments.Count == 0)
                {
                    <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun messaggio.</p>
                }
                else
                {
                    <div class="px-5 py-4 space-y-4 bg-slate-50/50">
                        @foreach (var c in _t.Comments)
                        {
                            <div class="flex @(c.AuthorIsStaff ? "justify-end" : "justify-start")">
                                <div class="max-w-[78%]">
                                    <div class="flex items-center gap-2 mb-1 text-xs text-slate-400 @(c.AuthorIsStaff ? "justify-end" : "")">
                                        <span class="font-medium text-slate-600">@c.AuthorName</span>
                                        <span>@c.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                        @if (c.IsInternal) { <span class="rounded bg-amber-100 text-amber-700 px-1.5 py-0.5 font-medium">interno</span> }
                                    </div>
                                    <div class="rounded-2xl px-4 py-2 text-sm whitespace-pre-wrap @(c.IsInternal ? "bg-amber-50 border border-amber-200 text-amber-900" : c.AuthorIsStaff ? "bg-indigo-600 text-white" : "bg-white border border-slate-200 text-slate-700")">@c.Body</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                <div class="px-5 py-4 border-t border-slate-200">
                    <textarea @bind="_comment" rows="2" placeholder="Scrivi un commento…" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
                    <div class="mt-2 flex items-center justify-between">
                        @if (_isStaff) { <label class="flex items-center gap-2 text-xs text-slate-600"><input type="checkbox" @bind="_internal" class="rounded border-slate-300" /> Nota interna</label> }
                        else { <span></span> }
                        <button @onclick="AddComment" class="rounded-lg bg-indigo-600 px-4 py-1.5 text-sm font-semibold text-white hover:bg-indigo-700">Invia</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Assegnazione</h2>
                @if (_t.AssignedUserId is not null)
                {
                    <p class="text-sm text-slate-700 font-medium">@_t.AssignedUserName</p>
                    @if (_t.AssignedUnitName is not null) { <p class="text-xs text-slate-400">Unit: @_t.AssignedUnitName</p> }
                }
                else
                {
                    <p class="text-sm text-slate-400">Nessuna assegnazione.</p>
                }
                @if (_isPm)
                {
                    <div class="mt-3 flex gap-2">
                        <button @onclick="OpenAssign" class="flex-1 rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Assegna</button>
                        @if (_t.AssignedUserId is not null)
                        {
                            <button @onclick="Unassign" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Rimuovi</button>
                        }
                    </div>
                }
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Azioni</h2>
                @if (_msg is not null) { <div class="mb-3 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs text-emerald-700">@_msg</div> }

                @if (_isStaff)
                {
                    @if (_takeChooser)
                    {
                        <label class="block text-sm font-medium text-slate-700">Gestisci con la Unit</label>
                        <select @bind="_takeUnitId" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                            @foreach (var u in _myUnits) { <option value="@u.UnitId">@u.Name</option> }
                        </select>
                        <button @onclick="ConfirmTake" class="mt-2 w-full rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Conferma presa in carico</button>
                    }
                    else
                    {
                        <button @onclick="Take" class="w-full rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Prendi in carico</button>
                    }

                    <label class="block text-sm font-medium text-slate-700 mt-4">Stato</label>
                    <select @bind="_statusSel" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                        <option value="0">Aperto</option><option value="1">In lavorazione</option><option value="2">In attesa</option><option value="3">Risolto</option><option value="4">Chiuso</option>
                    </select>
                    <button @onclick="ChangeStatus" class="mt-2 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium hover:bg-slate-50">Aggiorna stato</button>
                }
                <button @onclick="Close" class="mt-2 w-full rounded-lg bg-slate-800 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-900">Chiudi ticket</button>
            </div>
        </div>
    </div>

    <Modal Visible="_showAssign" Title="Assegna ticket" MaxWidth="max-w-md" OnClose="() => _showAssign = false">
        <div class="space-y-3">
            <Field Label="Unit">
                <select @bind="_asgUnitId" @bind:after="OnAsgUnitChanged" class="@Inp">
                    <option value="">— seleziona —</option>
                    @foreach (var u in _managedUnits) { <option value="@u.Id">@u.Name</option> }
                </select>
            </Field>
            @if (!string.IsNullOrEmpty(_asgUnitId))
            {
                <Field Label="Utente">
                    @if (_asgMembers.Count == 0)
                    {
                        <p class="text-xs text-slate-400 mt-1">Nessun membro in questa Unit. Aggiungi membri da “Unit”.</p>
                    }
                    else
                    {
                        <select @bind="_asgUserId" class="@Inp">
                            <option value="">— seleziona —</option>
                            @foreach (var m in _asgMembers) { <option value="@m.UserId">@MemberName(m)@(m.IsManager ? " (PM)" : "")</option> }
                        </select>
                    }
                </Field>
            }
        </div>
        <div class="mt-5 flex items-center justify-end gap-2">
            <button @onclick="() => _showAssign = false" class="@BtnGhost">Annulla</button>
            <button @onclick="Assign" disabled="@(string.IsNullOrEmpty(_asgUserId))" class="@BtnPrimary">Assegna</button>
        </div>
    </Modal>
}

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700 disabled:opacity-50";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    [Parameter] public int Id { get; set; }
    private TicketDetail? _t;
    private bool _loading = true, _isStaff, _isPm, _uploading;
    private string _comment = ""; private bool _internal; private int _statusSel; private string? _msg;

    private List<MyUnit> _myUnits = new();
    private bool _takeChooser; private string _takeUnitId = "";

    private List<UnitRow> _managedUnits = new();
    private List<UnitMemberDto> _asgMembers = new();
    private bool _showAssign; private string _asgUnitId = ""; private string _asgUserId = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _isStaff = auth.User.IsInRole("Admin") || auth.User.IsInRole("Agent") || auth.User.IsInRole("PM");
        _isPm = auth.User.IsInRole("PM") || auth.User.IsInRole("Admin");
        if (_isStaff) { try { _myUnits = await Api.GetMyUnitsAsync(); } catch { } }
        if (_isPm) { try { _managedUnits = await Api.GetUnitsAsync(); } catch { } }
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _t = await Api.GetTicketAsync(Id); if (_t is not null) _statusSel = (int)_t.Status; }
        catch { _t = null; }
        _loading = false;
    }

    private static string MemberName(UnitMemberDto m) =>
        string.IsNullOrWhiteSpace($"{m.FirstName} {m.LastName}".Trim()) ? m.Email : $"{m.FirstName} {m.LastName}".Trim();

    private static string FmtSize(long b) =>
        b < 1024 ? $"{b} B" : b < 1024 * 1024 ? $"{b / 1024.0:0.#} KB" : $"{b / (1024.0 * 1024):0.#} MB";

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_comment)) return;
        var r = await Api.AddCommentAsync(Id, new AddCommentRequest(_comment.Trim(), _internal && _isStaff));
        if (r.IsSuccessStatusCode) { _comment = ""; _internal = false; await Load(); }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        _uploading = true; _msg = null;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(20 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(fileContent, "file", file.Name);
            var r = await Api.UploadAttachmentAsync(Id, content);
            _msg = r.IsSuccessStatusCode ? "Allegato caricato." : $"Errore upload ({(int)r.StatusCode}).";
        }
        catch (Exception ex) { _msg = $"Errore upload: {ex.Message}"; }
        _uploading = false;
        await Load();
    }

    private async Task Download(TicketAttachmentDto a)
    {
        try
        {
            var bytes = await Api.GetAttachmentBytesAsync(Id, a.Id);
            await JS.InvokeVoidAsync("downloadFile", a.FileName, a.ContentType, Convert.ToBase64String(bytes));
        }
        catch (Exception ex) { _msg = $"Errore download: {ex.Message}"; }
    }

    private async Task ChangeStatus()
    {
        var r = await Api.ChangeStatusAsync(Id, (TicketStatus)_statusSel);
        _msg = r.IsSuccessStatusCode ? "Stato aggiornato." : "Errore.";
        await Load();
    }

    private async Task Take()
    {
        if (_myUnits.Count > 1) { _takeUnitId = _myUnits[0].UnitId.ToString(); _takeChooser = true; return; }
        await DoTake(_myUnits.Count == 1 ? _myUnits[0].UnitId : (int?)null);
    }

    private async Task ConfirmTake()
    {
        await DoTake(int.TryParse(_takeUnitId, out var u) ? u : (int?)null);
        _takeChooser = false;
    }

    private async Task DoTake(int? unitId)
    {
        var r = await Api.TakeAsync(Id, unitId);
        _msg = r.IsSuccessStatusCode ? "Preso in carico." : "Errore presa in carico.";
        await Load();
    }

    private async Task Close()
    {
        var r = await Api.CloseAsync(Id);
        _msg = r.IsSuccessStatusCode ? "Ticket chiuso." : "Errore.";
        await Load();
    }

    private void OpenAssign()
    {
        _asgUnitId = ""; _asgUserId = ""; _asgMembers = new(); _showAssign = true;
    }

    private async Task OnAsgUnitChanged()
    {
        _asgMembers = new(); _asgUserId = "";
        if (int.TryParse(_asgUnitId, out var uid))
        {
            var d = await Api.GetUnitAsync(uid);
            _asgMembers = d?.Members ?? new();
        }
    }

    private async Task Assign()
    {
        if (!int.TryParse(_asgUnitId, out var unit) || string.IsNullOrEmpty(_asgUserId)) return;
        var r = await Api.AssignAsync(Id, _asgUserId, unit);
        _msg = r.IsSuccessStatusCode ? "Assegnato." : "Errore assegnazione.";
        _showAssign = false;
        await Load();
    }

    private async Task Unassign()
    {
        var r = await Api.UnassignAsync(Id);
        _msg = r.IsSuccessStatusCode ? "Assegnazione rimossa." : "Errore.";
        await Load();
    }
}
