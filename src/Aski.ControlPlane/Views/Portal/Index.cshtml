@model PortalIndexViewModel

<div class="grid lg:grid-cols-3 gap-6">
    <!-- Lista tenant -->
    <div class="lg:col-span-2 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200">
            <h2 class="font-semibold text-slate-900">Aziende clienti (@Model.Tenants.Count)</h2>
        </div>
        @if (Model.Tenants.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun tenant registrato →</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr>
                        <th class="px-5 py-3 font-medium">Azienda</th>
                        <th class="px-5 py-3 font-medium">Email</th>
                        <th class="px-5 py-3 font-medium">Progetti</th>
                        <th class="px-5 py-3 font-medium">Abbonamenti</th>
                        <th class="px-5 py-3 font-medium">Stripe</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var t in Model.Tenants)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-5 py-3 font-medium text-slate-900">@t.CompanyName</td>
                            <td class="px-5 py-3 text-slate-600">@t.BillingEmail</td>
                            <td class="px-5 py-3 text-slate-600">@t.Projects.Count</td>
                            <td class="px-5 py-3 text-slate-600">@t.Subscriptions.Count</td>
                            <td class="px-5 py-3">
                                @if (t.StripeCustomerId is not null)
                                {
                                    <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700">cliente</span>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400">—</span>
                                }
                            </td>
                            <td class="px-5 py-3 text-right">
                                <a href="/Portal/Tenant/@t.Id" class="text-xs text-indigo-600 hover:underline">Apri →</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Registrazione -->
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm h-fit">
        <h2 class="font-semibold text-slate-900 mb-4">Registra azienda</h2>
        <form asp-action="Register" method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700">Ragione sociale</label>
                <input name="CompanyName" required placeholder="Acme Srl" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Email fatturazione</label>
                <input name="BillingEmail" type="email" required placeholder="billing@acme.it" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <button type="submit" class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Registra tenant</button>
        </form>
    </div>
</div>
