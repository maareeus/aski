@page "/"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<h1 class="text-2xl font-bold tracking-tight text-slate-900 mb-1">Dashboard</h1>
<p class="text-sm text-slate-500 mb-6">Panoramica dei ticket di assistenza.</p>

@if (_loading)
{
    <p class="text-sm text-slate-400">Caricamento…</p>
}
else if (_error is not null)
{
    <div class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_error</div>
}
else
{
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        <Stat Label="Totali" Value="@_all.Count" Accent="text-slate-900" />
        <Stat Label="Aperti" Value="@Count(TicketStatus.Open)" Accent="text-blue-600" />
        <Stat Label="In lavorazione" Value="@Count(TicketStatus.InProgress)" Accent="text-indigo-600" />
        <Stat Label="Risolti" Value="@Count(TicketStatus.Resolved)" Accent="text-emerald-600" />
        <Stat Label="Chiusi" Value="@Count(TicketStatus.Closed)" Accent="text-slate-500" />
    </div>

    <div class="mt-8 rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
            <h2 class="font-semibold text-slate-900">Ticket recenti</h2>
            <a href="tickets" class="text-sm text-indigo-600 hover:underline">Vedi tutti →</a>
        </div>
        @if (_all.Count == 0)
        {
            <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun ticket.</p>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="text-left text-slate-500 border-b border-slate-100">
                    <tr><th class="px-5 py-3 font-medium">#</th><th class="px-5 py-3 font-medium">Titolo</th>
                        <th class="px-5 py-3 font-medium">Priorità</th><th class="px-5 py-3 font-medium">Stato</th>
                        <th class="px-5 py-3 font-medium">Aggiornato</th></tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var t in _all.Take(8))
                    {
                        <tr class="hover:bg-slate-50 cursor-pointer" @onclick="() => Open(t.Id)">
                            <td class="px-5 py-3 text-slate-400">@t.Id</td>
                            <td class="px-5 py-3 font-medium text-slate-900">@t.Title</td>
                            <td class="px-5 py-3"><PriorityBadge Priority="t.Priority" /></td>
                            <td class="px-5 py-3"><StatusBadge Status="t.Status" /></td>
                            <td class="px-5 py-3 text-slate-500">@t.UpdatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private List<TicketListItem> _all = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _all = await Api.GetTicketsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private int Count(TicketStatus s) => _all.Count(t => t.Status == s);
    private void Open(int id) => Nav.NavigateTo($"tickets/{id}");
}
