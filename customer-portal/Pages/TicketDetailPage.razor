@page "/tickets/{Id:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient Api
@inject IJSRuntime JS

<a href="/" class="text-sm text-slate-500 hover:text-slate-700">← I miei ticket</a>

@if (_loading)
{
    <p class="mt-4 text-sm text-slate-400">Caricamento…</p>
}
else if (_t is null)
{
    <p class="mt-4 text-sm text-rose-600">Ticket non trovato.</p>
}
else
{
    var closed = _t.Status == TicketStatus.Closed;

    <div class="mt-3">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">@_t.Title</h1>
        <div class="mt-2 flex items-center gap-2">
            <span class="font-mono text-xs text-indigo-600">@(_t.Number ?? $"#{_t.Id}")</span>
            <StatusBadge Status="_t.Status" />
            <PriorityBadge Priority="_t.Priority" />
        </div>
    </div>

    @if (closed)
    {
        <div class="mt-4 rounded-lg border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-600">
            Questo ticket è <strong>chiuso</strong>. Non sono ammesse ulteriori operazioni. Per un nuovo problema apri un nuovo ticket.
        </div>
    }

    <div class="mt-6 grid lg:grid-cols-4 gap-6">
        <div class="lg:col-span-3 space-y-6">
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-1">Descrizione</h2>
                <p class="text-sm text-slate-600 whitespace-pre-wrap">@(_t.Description ?? "—")</p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="px-5 py-4 border-b border-slate-200"><h2 class="font-semibold text-slate-900">Conversazione</h2></div>
                @{ var visible = _t.Comments.Where(c => !c.IsInternal).OrderByDescending(c => c.CreatedAtUtc).ToList(); }
                @if (visible.Count == 0)
                {
                    <p class="px-5 py-6 text-center text-sm text-slate-400">Nessun messaggio.</p>
                }
                else
                {
                    <div class="px-5 py-4 space-y-4 bg-slate-50/50">
                        @foreach (var c in visible)
                        {
                            <div class="flex @(c.AuthorIsStaff ? "justify-end" : "justify-start")">
                                <div class="max-w-[78%]">
                                    <div class="flex items-center gap-2 mb-1 text-xs text-slate-400 @(c.AuthorIsStaff ? "justify-end" : "")">
                                        <span class="font-medium text-slate-600">@c.AuthorName</span>
                                        <span>@c.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                    </div>
                                    <div class="rounded-2xl px-4 py-2 text-sm whitespace-pre-wrap @(c.AuthorIsStaff ? "bg-indigo-600 text-white" : "bg-white border border-slate-200 text-slate-700")">@c.Body</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                @if (!closed)
                {
                    <div class="px-5 py-4 border-t border-slate-200">
                        <textarea @bind="_comment" rows="2" placeholder="Scrivi una risposta…" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
                        <div class="mt-2 flex justify-end">
                            <button @onclick="AddComment" class="rounded-lg bg-indigo-600 px-4 py-1.5 text-sm font-semibold text-white hover:bg-indigo-700">Invia</button>
                        </div>
                    </div>
                }
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                    <h2 class="font-semibold text-slate-900">Allegati</h2>
                    @if (!closed)
                    {
                        <label class="cursor-pointer rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50">
                            @(_uploading ? "Caricamento…" : "+ Allega file")
                            <InputFile OnChange="OnFileSelected" class="hidden" disabled="@_uploading" />
                        </label>
                    }
                </div>
                @if (_t.Attachments.Count == 0)
                {
                    <p class="text-sm text-slate-400">Nessun allegato.</p>
                }
                else
                {
                    <ul class="divide-y divide-slate-100">
                        @foreach (var a in _t.Attachments)
                        {
                            <li class="flex items-center justify-between py-2 text-sm">
                                <div>
                                    <span class="font-medium text-slate-700">@a.FileName</span>
                                    <span class="text-slate-400 text-xs ml-2">@FmtSize(a.Size)</span>
                                </div>
                                <button @onclick="() => Download(a)" class="text-indigo-600 hover:text-indigo-800 font-medium">Scarica</button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="space-y-6">
            @if (!closed)
            {
                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    @if (_msg is not null) { <div class="mb-3 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs text-emerald-700">@_msg</div> }
                    <button @onclick="Remind" class="w-full rounded-lg border border-amber-300 px-3 py-2 text-sm font-medium text-amber-700 hover:bg-amber-50">🔔 Sollecita</button>
                    <p class="mt-2 text-xs text-slate-400">Avvisa gli operatori che attendi una risposta.</p>
                </div>
            }
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="font-semibold text-slate-900 mb-3">Dettagli</h2>
                <dl class="space-y-2 text-sm">
                    <div><dt class="text-slate-400">Operatore</dt><dd class="text-slate-700">@(_t.AssignedUserName ?? "In attesa di assegnazione")</dd></div>
                    @if (_t.AssignedUserEmail is not null) { <div><dt class="text-slate-400">Contatto</dt><dd class="text-slate-700">@_t.AssignedUserEmail</dd></div> }
                    <div><dt class="text-slate-400">Aperto il</dt><dd class="text-slate-700">@_t.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd></div>
                    <div><dt class="text-slate-400">Aggiornato</dt><dd class="text-slate-700">@_t.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd></div>
                </dl>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private TicketDetail? _t;
    private bool _loading = true, _uploading;
    private string _comment = "";
    private string? _msg;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try { _t = await Api.GetTicketAsync(Id); }
        catch { _t = null; }
        _loading = false;
    }

    private static string FmtSize(long b) =>
        b < 1024 ? $"{b} B" : b < 1024 * 1024 ? $"{b / 1024.0:0.#} KB" : $"{b / (1024.0 * 1024):0.#} MB";

    private async Task Remind()
    {
        var r = await Api.RemindAsync(Id);
        _msg = r.IsSuccessStatusCode ? "Sollecito inviato." : "Errore.";
        await Load();
    }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_comment)) return;
        var r = await Api.AddCommentAsync(Id, _comment.Trim());
        if (r.IsSuccessStatusCode) { _comment = ""; await Load(); }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        _uploading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(20 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(fileContent, "file", file.Name);
            await Api.UploadAttachmentAsync(Id, content);
        }
        catch { }
        _uploading = false;
        await Load();
    }

    private async Task Download(TicketAttachmentDto a)
    {
        try
        {
            var bytes = await Api.GetAttachmentBytesAsync(Id, a.Id);
            await JS.InvokeVoidAsync("downloadFile", a.FileName, a.ContentType, Convert.ToBase64String(bytes));
        }
        catch { }
    }
}
