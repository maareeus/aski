@page "/clients"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api

<AppTitle Suffix="Clienti" />

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Clienti</h1>
        <p class="text-sm text-slate-500">Utenti delle aziende clienti.</p>
    </div>
    <button @onclick="OpenCreate" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Nuovo cliente</button>
</div>

<div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    @if (_items.Count == 0)
    {
        <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun cliente.</p>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="text-left text-slate-500 border-b border-slate-100">
                <tr><th class="px-5 py-3 font-medium">Nome</th><th class="px-5 py-3 font-medium">Ruolo az.</th>
                    <th class="px-5 py-3 font-medium">Azienda</th><th class="px-5 py-3 font-medium">Email</th>
                    <th class="px-5 py-3 font-medium">Telefono</th><th class="px-5 py-3"></th></tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var u in _items)
                {
                    <tr class="hover:bg-slate-50">
                        <td class="px-5 py-3 font-medium text-slate-900">@(string.IsNullOrWhiteSpace(u.Display) ? "—" : u.Display)</td>
                        <td class="px-5 py-3 text-slate-600">@(u.JobTitle ?? "—")</td>
                        <td class="px-5 py-3 text-slate-600">@(u.CompanyName ?? "—")</td>
                        <td class="px-5 py-3 text-slate-600">@u.Email</td>
                        <td class="px-5 py-3 text-slate-600">@(u.Phone ?? "—")</td>
                        <td class="px-5 py-3 text-right space-x-3">
                            <button @onclick="() => OpenEdit(u)" class="text-xs text-indigo-600 hover:underline">Modifica</button>
                            <button @onclick="() => OpenPassword(u)" class="text-xs text-indigo-600 hover:underline">Password</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Crea -->
<Modal Visible="_showCreate" Title="Nuovo cliente" MaxWidth="max-w-xl" OnClose="() => _showCreate = false">
    @if (_err is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_err</div> }
    <div class="grid grid-cols-2 gap-3">
        <Field Label="Nome"><input @bind="_first" class="@Inp" /></Field>
        <Field Label="Cognome"><input @bind="_last" class="@Inp" /></Field>
        <Field Label="Ruolo in azienda"><input @bind="_job" class="@Inp" /></Field>
        <Field Label="Telefono"><input @bind="_phone" class="@Inp" /></Field>
        <Field Label="Email *"><input @bind="_email" class="@Inp" /></Field>
        <Field Label="Password * (min 8)"><input @bind="_pwd" type="password" class="@Inp" /></Field>
        <div class="col-span-2"><Field Label="Azienda *">
            <select @bind="_companyId" class="@Inp">
                <option value="">— seleziona —</option>
                @foreach (var c in _companies) { <option value="@c.Id">@c.Name</option> }
            </select>
        </Field></div>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showCreate = false" class="@BtnGhost">Annulla</button>
        <button @onclick="Create" class="@BtnPrimary">Crea</button>
    </div>
</Modal>

<!-- Imposta password -->
<Modal Visible="_showPwd" Title="@($"Imposta password · {_editing?.Email}")" OnClose="() => _showPwd = false">
    @if (_pwErr is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_pwErr</div> }
    @if (_pwMsg is not null) { <div class="mb-3 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700">@_pwMsg</div> }
    <p class="text-sm text-slate-500 mb-3">Definisci una nuova password per il cliente. Verrà sovrascritta quella attuale.</p>
    <Field Label="Nuova password (min 8)"><input @bind="_newPwd" type="text" class="@Inp font-mono" /></Field>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showPwd = false" class="@BtnGhost">Chiudi</button>
        <button @onclick="SetPassword" class="@BtnPrimary">Imposta password</button>
    </div>
</Modal>

<!-- Modifica -->
<Modal Visible="_showEdit" Title="Modifica cliente" MaxWidth="max-w-xl" OnClose="() => _showEdit = false">
    <div class="grid grid-cols-2 gap-3">
        <Field Label="Nome"><input @bind="_first" class="@Inp" /></Field>
        <Field Label="Cognome"><input @bind="_last" class="@Inp" /></Field>
        <Field Label="Ruolo in azienda"><input @bind="_job" class="@Inp" /></Field>
        <Field Label="Telefono"><input @bind="_phone" class="@Inp" /></Field>
        <div class="col-span-2"><Field Label="Azienda">
            <select @bind="_companyId" class="@Inp">
                @foreach (var c in _companies) { <option value="@c.Id">@c.Name</option> }
            </select>
        </Field></div>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showEdit = false" class="@BtnGhost">Annulla</button>
        <button @onclick="SaveEdit" class="@BtnPrimary">Salva</button>
    </div>
</Modal>

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    private List<ClientRow> _items = new();
    private List<Company> _companies = new();
    private bool _showCreate, _showEdit, _showPwd;
    private string _email = ""; private string? _first, _last, _job, _phone; private string _pwd = ""; private string _companyId = ""; private string? _err;
    private string _newPwd = ""; private string? _pwErr, _pwMsg;
    private ClientRow? _editing;

    protected override async Task OnInitializedAsync()
    {
        try { _companies = await Api.GetCompaniesAsync(); } catch { }
        await Load();
    }
    private async Task Load() { try { _items = await Api.GetClientUsersAsync(); } catch { } }

    private void OpenCreate()
    {
        _email = ""; _first = _last = _job = _phone = null; _pwd = ""; _companyId = ""; _err = null; _showCreate = true;
    }

    private async Task Create()
    {
        _err = null;
        if (string.IsNullOrWhiteSpace(_email) || _pwd.Length < 8) { _err = "Email e password (min 8) obbligatorie."; return; }
        if (!int.TryParse(_companyId, out var co)) { _err = "Seleziona un'azienda."; return; }
        var resp = await Api.CreateUserAsync(new CreateUserRequest(_email.Trim(), _pwd, "Client", _first, _last, _job, _phone, co, null));
        if (!resp.IsSuccessStatusCode) { _err = $"Errore ({(int)resp.StatusCode})."; return; }
        _showCreate = false; await Load();
    }

    private void OpenPassword(ClientRow u)
    {
        _editing = u; _newPwd = ""; _pwErr = null; _pwMsg = null; _showPwd = true;
    }

    private async Task SetPassword()
    {
        _pwErr = null; _pwMsg = null;
        if (_editing is null) return;
        if (_newPwd.Length < 8) { _pwErr = "Password minimo 8 caratteri."; return; }
        var r = await Api.ResetPasswordAsync(_editing.Id, _newPwd);
        if (!r.IsSuccessStatusCode) { _pwErr = $"Errore ({(int)r.StatusCode})."; return; }
        _pwMsg = "Password impostata."; _newPwd = "";
    }

    private void OpenEdit(ClientRow u)
    {
        _editing = u; _first = u.FirstName; _last = u.LastName; _job = u.JobTitle; _phone = u.Phone;
        _companyId = u.CompanyId?.ToString() ?? ""; _showEdit = true;
    }

    private async Task SaveEdit()
    {
        if (_editing is null) return;
        int? co = int.TryParse(_companyId, out var c) ? c : null;
        await Api.UpdateUserAsync(_editing.Id, new UpdateUserRequest(_first, _last, _job, _phone, co));
        _showEdit = false; await Load();
    }
}
