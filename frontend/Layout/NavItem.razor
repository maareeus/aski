<NavLink class="flex items-center gap-3 rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900"
         ActiveClass="bg-indigo-50 text-indigo-700 font-semibold hover:bg-indigo-50"
         href="@Href" Match="Match">
    <span>@Icon</span><span>@Label</span>
</NavLink>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
}
