@model Aski.Shared.SubscriptionStatus
@{
    var (cls, label) = Model switch
    {
        SubscriptionStatus.Active => ("bg-emerald-100 text-emerald-700", "Attivo"),
        SubscriptionStatus.Pending => ("bg-amber-100 text-amber-700", "In attesa"),
        SubscriptionStatus.PastDue => ("bg-orange-100 text-orange-700", "Insoluto"),
        SubscriptionStatus.Suspended => ("bg-rose-100 text-rose-700", "Sospeso"),
        SubscriptionStatus.Canceled => ("bg-slate-100 text-slate-600", "Cancellato"),
        _ => ("bg-slate-100 text-slate-500", Model.ToString())
    };
}
<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @cls">@label</span>
