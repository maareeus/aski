@page "/users"
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient Api
@inject NavigationManager Nav

<AppTitle Suffix="Utenti" />

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Utenti</h1>
        <p class="text-sm text-slate-500">Staff: Admin, PM, Agent. Agli Agent/PM assegni i software di competenza.</p>
    </div>
    <button @onclick="OpenCreate" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Nuovo utente</button>
</div>

<div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-x-auto">
    @if (_items.Count == 0)
    {
        <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun utente.</p>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="text-left text-slate-500 border-b border-slate-100">
                <tr><th class="px-5 py-3 font-medium">Nome</th><th class="px-5 py-3 font-medium">Email</th>
                    <th class="px-5 py-3 font-medium">Ruolo in azienda</th><th class="px-5 py-3 font-medium">Ruolo</th>
                    <th class="px-5 py-3 font-medium">Software</th><th class="px-5 py-3 font-medium">Stato</th>
                    <th class="px-5 py-3 w-12"></th></tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var u in _items)
                {
                    <tr class="hover:bg-slate-50 cursor-pointer" @onclick="() => Open(u.Id)">
                        <td class="px-5 py-3 font-medium text-slate-900">@(string.IsNullOrWhiteSpace(u.Display) ? "—" : u.Display)</td>
                        <td class="px-5 py-3 text-slate-600">@u.Email</td>
                        <td class="px-5 py-3 text-slate-600">@(u.JobTitle ?? "—")</td>
                        <td class="px-5 py-3 text-slate-600">@string.Join(", ", u.Roles)</td>
                        <td class="px-5 py-3 text-slate-600">@u.SoftwareIds.Count</td>
                        <td class="px-5 py-3">@if (u.IsActive) { <span class="rounded-full bg-emerald-100 text-emerald-700 px-2 py-0.5 text-xs font-medium">Attivo</span> } else { <span class="rounded-full bg-slate-100 text-slate-500 px-2 py-0.5 text-xs font-medium">Disattivo</span> }</td>
                        <td class="px-5 py-3 text-right text-slate-400">→</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Crea -->
<Modal Visible="_showCreate" Title="Nuovo utente" MaxWidth="max-w-2xl" OnClose="() => _showCreate = false">
    @if (_err is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_err</div> }
    <div class="grid grid-cols-2 gap-3">
        <Field Label="Nome"><input @bind="_first" class="@Inp" /></Field>
        <Field Label="Cognome"><input @bind="_last" class="@Inp" /></Field>
        <Field Label="Ruolo in azienda"><input @bind="_job" class="@Inp" /></Field>
        <Field Label="Telefono"><input @bind="_phone" class="@Inp" /></Field>
        <Field Label="Email *"><input @bind="_email" class="@Inp" /></Field>
        <Field Label="Password * (min 8)"><input @bind="_pwd" type="password" class="@Inp" /></Field>
        <Field Label="Ruolo">
            <select @bind="_role" class="@Inp">
                <option value="Agent">Agent</option><option value="PM">PM</option><option value="Admin">Admin</option>
            </select>
        </Field>
    </div>
    <div class="mt-4">
        <p class="text-sm font-medium text-slate-700 mb-2">Software di competenza</p>
        <div class="grid grid-cols-3 gap-1 max-h-40 overflow-y-auto rounded-lg border border-slate-200 p-2">
            @foreach (var s in _allSoftware)
            {
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" checked="@_sel.Contains(s.Id)" @onchange="e => Toggle(s.Id, e)" class="rounded border-slate-300" />
                    <span class="text-slate-700">@s.Name</span>
                </label>
            }
        </div>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showCreate = false" class="@BtnGhost">Annulla</button>
        <button @onclick="Create" class="@BtnPrimary">Crea</button>
    </div>
</Modal>

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    private List<AppUserRow> _items = new();
    private List<Software> _allSoftware = new();

    private bool _showCreate;
    private string _email = ""; private string? _first, _last, _job, _phone; private string _pwd = "";
    private string _role = "Agent"; private string? _err;
    private HashSet<int> _sel = new();

    protected override async Task OnInitializedAsync()
    {
        try { _allSoftware = await Api.GetSoftwareAsync(); } catch { }
        await Load();
    }
    private async Task Load() { try { _items = await Api.GetUsersAsync(); } catch { } }

    private void Open(string id) => Nav.NavigateTo($"users/{id}");
    private void Toggle(int id, ChangeEventArgs e) { if ((bool)e.Value!) _sel.Add(id); else _sel.Remove(id); }

    private void OpenCreate()
    {
        _email = ""; _first = _last = _job = _phone = null; _pwd = ""; _role = "Agent"; _sel = new(); _err = null; _showCreate = true;
    }

    private async Task Create()
    {
        _err = null;
        if (string.IsNullOrWhiteSpace(_email) || _pwd.Length < 8) { _err = "Email e password (min 8) obbligatorie."; return; }
        var resp = await Api.CreateUserAsync(new CreateUserRequest(_email.Trim(), _pwd, _role, _first, _last, _job, _phone, null, _sel.ToList()));
        if (!resp.IsSuccessStatusCode) { _err = $"Errore ({(int)resp.StatusCode})."; return; }
        _showCreate = false; await Load();
    }
}
