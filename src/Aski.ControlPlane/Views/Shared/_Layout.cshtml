@{
    string nav(string controller) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), controller, StringComparison.OrdinalIgnoreCase)
            ? "bg-indigo-50 text-indigo-700 font-semibold"
            : "text-slate-600 hover:bg-slate-100 hover:text-slate-900";

    var isAdmin = User.IsInRole("SuperAdmin");
    var displayName = User.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Trim()[..1].ToUpper();
    var roleLabel = isAdmin ? "Super Admin" : "Cliente";
}
<!DOCTYPE html>
<html lang="it" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Aski") · Control Plane</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }
        body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }
    </style>
</head>
<body class="h-full bg-slate-50 text-slate-800 antialiased">
<div class="flex h-full min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden md:flex w-64 flex-col border-r border-slate-200 bg-white">
        <div class="flex items-center gap-2 px-6 h-16 border-b border-slate-200">
            <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold">A</div>
            <span class="text-lg font-bold tracking-tight">Aski</span>
            <span class="ml-auto text-[10px] uppercase tracking-wider text-slate-400">Control Plane</span>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
            @if (isAdmin)
            {
                <p class="px-3 pb-1 pt-2 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Super Admin</p>
                <a href="/Dashboard" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("Dashboard")">📊 Dashboard</a>
                <a href="/StripeAdmin" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("StripeAdmin")">💳 Stripe</a>
                <a href="/PlanAdmin" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("PlanAdmin")">🏷️ Piani</a>
                <a href="/ServerAdmin" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("ServerAdmin")">🖥️ Server</a>
                <a href="/AdminCustomers" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("AdminCustomers")">🏢 Clienti</a>
                <a href="/AdminAudit" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("AdminAudit")">📜 Audit</a>
            }
            else
            {
                <p class="px-3 pb-1 pt-2 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Il mio account</p>
                <a href="/Portal" class="flex items-center gap-3 rounded-lg px-3 py-2 @nav("Portal")">🚀 I miei progetti</a>
            }
        </nav>
        <div class="px-6 py-4 border-t border-slate-200 text-xs text-slate-400">
            v1 · @DateTime.UtcNow.Year
        </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
        <header class="h-16 border-b border-slate-200 bg-white/80 backdrop-blur flex items-center px-6 gap-4">
            <h1 class="text-base font-semibold text-slate-900">@(ViewData["Title"] ?? "Dashboard")</h1>
            @if (ViewData["Subtitle"] is string sub)
            {
                <span class="text-sm text-slate-400">@sub</span>
            }
            <div class="ml-auto flex items-center gap-3 text-sm text-slate-500">
                <div class="hidden sm:flex flex-col items-end leading-tight">
                    <span class="text-slate-700 font-medium">@displayName</span>
                    <span class="text-[11px] text-slate-400">@roleLabel</span>
                </div>
                <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-semibold">@initials</div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">Esci</button>
                </form>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-6">
            @if (TempData["Success"] is string ok)
            {
                <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">@ok</div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">@err</div>
            }
            @RenderBody()
        </main>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
