@page "/tickets"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Ticket</h1>
        <p class="text-sm text-slate-500">Gestione richieste di assistenza.</p>
    </div>
    @if (_canCreate)
    {
        <button @onclick="OpenCreate" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Nuovo ticket</button>
    }
</div>

<div class="flex gap-2 mb-4 text-sm">
    <button @onclick="() => Filter(null)" class="@FilterCls(null)">Tutti</button>
    <button @onclick="() => Filter(TicketStatus.Open)" class="@FilterCls(TicketStatus.Open)">Aperti</button>
    <button @onclick="() => Filter(TicketStatus.InProgress)" class="@FilterCls(TicketStatus.InProgress)">In lavorazione</button>
    <button @onclick="() => Filter(TicketStatus.Resolved)" class="@FilterCls(TicketStatus.Resolved)">Risolti</button>
    <button @onclick="() => Filter(TicketStatus.Closed)" class="@FilterCls(TicketStatus.Closed)">Chiusi</button>
</div>

<div class="rounded-xl border border-slate-200 bg-white shadow-sm">
    @if (_loading)
    {
        <p class="px-5 py-8 text-center text-sm text-slate-400">Caricamento…</p>
    }
    else if (_items.Count == 0)
    {
        <p class="px-5 py-8 text-center text-sm text-slate-400">Nessun ticket.</p>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="text-left text-slate-500 border-b border-slate-100">
                <tr><th class="px-5 py-3 font-medium">#</th><th class="px-5 py-3 font-medium">Titolo</th>
                    <th class="px-5 py-3 font-medium">Priorità</th><th class="px-5 py-3 font-medium">Stato</th>
                    <th class="px-5 py-3 font-medium">Aggiornato</th></tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var t in _items)
                {
                    <tr class="hover:bg-slate-50 cursor-pointer" @onclick="() => Open(t.Id)">
                        <td class="px-5 py-3 text-slate-400">@t.Id</td>
                        <td class="px-5 py-3 font-medium text-slate-900">@t.Title</td>
                        <td class="px-5 py-3"><PriorityBadge Priority="t.Priority" /></td>
                        <td class="px-5 py-3"><StatusBadge Status="t.Status" /></td>
                        <td class="px-5 py-3 text-slate-500">@t.UpdatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<Modal Visible="_showCreate" Title="Nuovo ticket" MaxWidth="max-w-xl" OnClose="() => _showCreate = false">
    @if (_createError is not null) { <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_createError</div> }
    <div class="space-y-3">
        <Field Label="Titolo *"><input @bind="_title" class="@Inp" /></Field>
        <Field Label="Descrizione"><textarea @bind="_desc" rows="3" class="@Inp"></textarea></Field>
        <div class="grid grid-cols-2 gap-3">
            <Field Label="Priorità">
                <select @bind="_priority" class="@Inp">
                    <option value="0">Bassa</option><option value="1">Normale</option><option value="2">Alta</option><option value="3">Urgente</option>
                </select>
            </Field>
            @if (_isAdmin)
            {
                <Field Label="Azienda *">
                    <select @bind="_companyId" @bind:after="OnCompanyChanged" class="@Inp">
                        <option value="">— seleziona —</option>
                        @foreach (var c in _companies) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </Field>
            }
            <Field Label="Software">
                <select @bind="_softwareId" @bind:after="OnSoftwareChanged" class="@Inp">
                    <option value="">—</option>
                    @foreach (var s in _software) { <option value="@s.Id">@s.Name</option> }
                </select>
            </Field>
            @if (_versions.Count > 0)
            {
                <Field Label="Versione">
                    <select @bind="_versionId" class="@Inp">
                        <option value="">—</option>
                        @foreach (var v in _versions) { <option value="@v.Id">v@(v.Version)</option> }
                    </select>
                </Field>
            }
        </div>
    </div>
    <div class="mt-5 flex items-center justify-end gap-2">
        <button @onclick="() => _showCreate = false" class="@BtnGhost">Annulla</button>
        <button @onclick="Create" class="@BtnPrimary">Crea ticket</button>
    </div>
</Modal>

@code {
    private const string Inp = "mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm";
    private const string BtnPrimary = "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700";
    private const string BtnGhost = "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50";

    private List<TicketListItem> _items = new();
    private List<Software> _software = new();
    private List<Company> _companies = new();
    private bool _loading = true;
    private TicketStatus? _filter;
    private bool _showCreate;
    private bool _isAdmin, _isClient, _canCreate;

    private string _title = ""; private string? _desc; private int _priority = 1;
    private string _softwareId = ""; private string _versionId = ""; private string _companyId = ""; private string? _createError;
    private List<SoftwareVersion> _versions = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _isAdmin = auth.User.IsInRole("Admin");
        _isClient = auth.User.IsInRole("Client");
        _canCreate = _isAdmin || _isClient;
        try
        {
            if (_isAdmin) _companies = await Api.GetCompaniesAsync();
            else _software = await Api.GetSoftwareAsync(); // client: software della propria azienda
        }
        catch { }
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _items = await Api.GetTicketsAsync(_filter); } catch { _items = new(); }
        _loading = false;
    }

    private async Task Filter(TicketStatus? s) { _filter = s; await Load(); }
    private void Open(int id) => Nav.NavigateTo($"tickets/{id}");

    private string FilterCls(TicketStatus? s) =>
        (_filter == s ? "bg-indigo-600 text-white" : "bg-white text-slate-600 border border-slate-300 hover:bg-slate-50")
        + " rounded-lg px-3 py-1.5 font-medium";

    private void OpenCreate()
    {
        _title = ""; _desc = null; _priority = 1; _softwareId = ""; _versionId = ""; _companyId = ""; _createError = null;
        _versions = new();
        _showCreate = true;
    }

    private async Task OnSoftwareChanged()
    {
        _versionId = ""; _versions = new();
        if (int.TryParse(_softwareId, out var sid))
        {
            try { _versions = await Api.GetVersionsAsync(sid); } catch { }
        }
    }

    // Admin: caricando l'azienda, mostro i software associati a quell'azienda.
    private async Task OnCompanyChanged()
    {
        _software = new(); _softwareId = "";
        if (int.TryParse(_companyId, out var cid))
        {
            var all = await Api.GetSoftwareAsync();
            var company = _companies.FirstOrDefault(c => c.Id == cid);
            _software = company is null ? all : all.Where(s => company.SoftwareIds.Contains(s.Id)).ToList();
        }
    }

    private async Task Create()
    {
        _createError = null;
        if (string.IsNullOrWhiteSpace(_title)) { _createError = "Titolo obbligatorio."; return; }
        int? sw = int.TryParse(_softwareId, out var s) ? s : null;
        int? ver = int.TryParse(_versionId, out var v) ? v : null;
        int? co = _isAdmin && int.TryParse(_companyId, out var c) ? c : null;
        if (_isAdmin && co is null) { _createError = "Seleziona un'azienda."; return; }

        var resp = await Api.CreateTicketAsync(new CreateTicketRequest(_title.Trim(), _desc, sw, ver, (TicketPriority)_priority, co));
        if (!resp.IsSuccessStatusCode) { _createError = $"Errore creazione ({(int)resp.StatusCode})."; return; }
        _showCreate = false; await Load();
    }
}


