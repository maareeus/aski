@page "/login"
@layout EmptyLayout
@inject AuthService Auth
@inject NavigationManager Nav
@inject BrandService Brand

<AppTitle Suffix="Accedi" />

<div class="min-h-screen flex items-center justify-center p-6 bg-slate-100">
    <div class="w-full max-w-sm">
        <div class="flex items-center justify-center gap-2 mb-6">
            @if (Brand.HasLogo)
            {
                <img src="@Brand.LogoUrl" alt="logo" class="h-10 w-10 rounded-xl object-contain" />
            }
            else
            {
                <div class="h-10 w-10 rounded-xl bg-indigo-600 text-white flex items-center justify-center font-extrabold text-xl">@(string.IsNullOrEmpty(Brand.Name) ? "A" : Brand.Name[..1].ToUpper())</div>
            }
            <span class="text-2xl font-bold tracking-tight text-slate-900">@Brand.Name</span>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
            <h1 class="text-lg font-semibold text-slate-900">Accedi</h1>
            <p class="text-sm text-slate-500 mb-5">Entra nel pannello di assistenza.</p>

            @if (_error is not null)
            {
                <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">@_error</div>
            }

            <EditForm Model="this" OnValidSubmit="DoLogin">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Email</label>
                        <input @bind="_email" type="email" autofocus
                               class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700">Password</label>
                        <input @bind="_password" type="password"
                               class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
                    </div>
                    <button type="submit" disabled="@_busy"
                            class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700 disabled:opacity-60">
                        @(_busy ? "Accesso…" : "Accedi")
                    </button>
                </div>
            </EditForm>
        </div>
        <p class="mt-6 text-center text-xs text-slate-400">@Brand.Name · Pannello assistenza</p>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await Brand.EnsureLoadedAsync();

    private async Task DoLogin()
    {
        _busy = true; _error = null;
        _error = await Auth.LoginAsync(_email, _password);
        _busy = false;
        if (_error is null) Nav.NavigateTo("/", forceLoad: false);
    }
}
