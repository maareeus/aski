@model StripeSettingsViewModel
@{
    string SetBadge(bool set) => set
        ? "<span class='inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700'>impostata</span>"
        : "<span class='inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500'>non impostata</span>";
}

<form asp-action="Save" method="post" class="max-w-4xl space-y-6">
    <!-- Toggle modalità -->
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="font-semibold text-slate-900">Modalità</h2>
                <p class="text-sm text-slate-500">Sandbox per simulazioni, Live per produzione. Le chiavi dei due ambienti restano separate.</p>
            </div>
            <label class="inline-flex items-center gap-3 cursor-pointer">
                <span class="text-sm font-medium @(Model.IsTestMode ? "text-amber-600" : "text-slate-400")">TEST</span>
                <span class="relative">
                    <input type="checkbox" name="IsTestMode" value="true" class="peer sr-only" @(Model.IsTestMode ? "checked" : "") />
                    <div class="h-6 w-11 rounded-full bg-emerald-500 peer-checked:bg-amber-500 transition"></div>
                    <div class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-white transition peer-checked:translate-x-0 translate-x-5"></div>
                </span>
                <span class="text-sm font-medium @(Model.IsTestMode ? "text-slate-400" : "text-emerald-600")">LIVE</span>
            </label>
        </div>
        <p class="mt-3 text-xs text-slate-400">Stato attuale: <strong>@(Model.IsTestMode ? "TEST (sandbox)" : "LIVE")</strong></p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <!-- TEST -->
        <div class="rounded-xl border border-amber-200 bg-amber-50/40 p-5 shadow-sm space-y-4">
            <h3 class="font-semibold text-amber-700 flex items-center gap-2">🧪 Ambiente TEST</h3>
            <div>
                <label class="block text-sm font-medium text-slate-700">Publishable key</label>
                <input name="TestPublishableKey" value="@Model.TestPublishableKey" placeholder="pk_test_..."
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Secret key @Html.Raw(SetBadge(Model.TestSecretKeySet))</label>
                <input name="NewTestSecretKey" type="password" placeholder="sk_test_... (vuoto = invariata)"
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Webhook secret @Html.Raw(SetBadge(Model.TestWebhookSecretSet))</label>
                <input name="NewTestWebhookSecret" type="password" placeholder="whsec_... (vuoto = invariata)"
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
        </div>

        <!-- LIVE -->
        <div class="rounded-xl border border-emerald-200 bg-emerald-50/40 p-5 shadow-sm space-y-4">
            <h3 class="font-semibold text-emerald-700 flex items-center gap-2">🚀 Ambiente LIVE</h3>
            <div>
                <label class="block text-sm font-medium text-slate-700">Publishable key</label>
                <input name="LivePublishableKey" value="@Model.LivePublishableKey" placeholder="pk_live_..."
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Secret key @Html.Raw(SetBadge(Model.LiveSecretKeySet))</label>
                <input name="NewLiveSecretKey" type="password" placeholder="sk_live_... (vuoto = invariata)"
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700">Webhook secret @Html.Raw(SetBadge(Model.LiveWebhookSecretSet))</label>
                <input name="NewLiveWebhookSecret" type="password" placeholder="whsec_... (vuoto = invariata)"
                       class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
            </div>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <button type="submit" class="rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">Salva impostazioni</button>
        <p class="text-xs text-slate-400">I segreti sono cifrati a riposo (DataProtection). I campi password vuoti non sovrascrivono il valore esistente.</p>
    </div>
</form>
