<!DOCTYPE html>
<html lang="it" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Aski")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body{font-family:'Inter',ui-sans-serif,system-ui,sans-serif}</style>
</head>
<body class="h-full bg-slate-100 text-slate-800 antialiased">
<div class="min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md">
        <div class="flex items-center justify-center gap-2 mb-6">
            <div class="h-10 w-10 rounded-xl bg-indigo-600 flex items-center justify-center text-white font-bold text-xl">A</div>
            <span class="text-2xl font-bold tracking-tight">Aski</span>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
            @if (ViewData["Error"] is string err)
            {
                <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">@err</div>
            }
            @RenderBody()
        </div>
        <p class="mt-6 text-center text-xs text-slate-400">Aski · Control Plane</p>
    </div>
</div>
</body>
</html>
